# ═══════════════════════════════════════════════════════════════════════════
# Frontend Root .gitignore
# ═══════════════════════════════════════════════════════════════════════════

# ── Dependencies ──────────────────────────────────────────────────────────────
node_modules/
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Build Output ──────────────────────────────────────────────────────────────
dist/
build/
.cache/
.next/
out/

# ── Environment Variables ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local

# ── IDE & Editor ──────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
desktop.ini

# ── Temporary Files ───────────────────────────────────────────────────────────
*.tmp
*.bak
.#*

# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/

# ── Tanstack & Build Tools ────────────────────────────────────────────────────
.tanstack/
.wrangler/
